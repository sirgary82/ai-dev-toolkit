---
/**
 * Callout component — used for tips, warnings, notes, and coming-soon notices.
 *
 * Usage in MDX:
 *   import Callout from '../../components/Callout.astro';
 *   <Callout type="tip">Your message here.</Callout>
 *   <Callout type="coming-soon">This guide is coming soon.</Callout>
 */
interface Props {
  type?: 'tip' | 'warning' | 'note' | 'coming-soon';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const config = {
  tip: {
    icon: '💡',
    defaultTitle: 'Tip',
    classes: 'callout--tip',
  },
  warning: {
    icon: '⚠️',
    defaultTitle: 'Warning',
    classes: 'callout--warning',
  },
  note: {
    icon: 'ℹ️',
    defaultTitle: 'Note',
    classes: 'callout--note',
  },
  'coming-soon': {
    icon: '🚧',
    defaultTitle: 'Coming Soon',
    classes: 'callout--coming-soon',
  },
};

const { icon, defaultTitle, classes } = config[type];
const displayTitle = title ?? defaultTitle;
---

<aside class={`callout ${classes}`}>
  <p class="callout__title">
    <span class="callout__icon" aria-hidden="true">{icon}</span>
    {displayTitle}
  </p>
  <div class="callout__body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    border-radius: 0.5rem;
    border-left: 4px solid;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
  }

  .callout__title {
    font-weight: 600;
    font-size: 0.95rem;
    margin: 0 0 0.5rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .callout__icon {
    font-size: 1rem;
  }

  .callout__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .callout--tip {
    background: color-mix(in srgb, var(--sl-color-green) 10%, transparent);
    border-color: var(--sl-color-green);
    color: var(--sl-color-text);
  }

  .callout--tip .callout__title {
    color: var(--sl-color-green-high);
  }

  .callout--warning {
    background: color-mix(in srgb, var(--sl-color-orange) 10%, transparent);
    border-color: var(--sl-color-orange);
    color: var(--sl-color-text);
  }

  .callout--warning .callout__title {
    color: var(--sl-color-orange-high);
  }

  .callout--note {
    background: color-mix(in srgb, var(--sl-color-blue) 10%, transparent);
    border-color: var(--sl-color-blue);
    color: var(--sl-color-text);
  }

  .callout--note .callout__title {
    color: var(--sl-color-blue-high);
  }

  .callout--coming-soon {
    background: color-mix(in srgb, var(--sl-color-purple) 10%, transparent);
    border-color: var(--sl-color-purple);
    color: var(--sl-color-text);
  }

  .callout--coming-soon .callout__title {
    color: var(--sl-color-purple-high);
  }
</style>
